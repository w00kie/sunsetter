{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "sunsetter",
  "main": "worker/main.py",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": ["python_workers"],
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "sunset.rejete.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
